rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return (isVerified() || isSignedIn()) && (
        request.auth.token.email == 'musen.almajidi.alallaf@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'subscription', 'freeUploadsUsed', 'level', 'dialect']) &&
             data.uid is string &&
             data.subscription in ['free', 'paid'] &&
             data.freeUploadsUsed is number &&
             data.level in ['Beginner', 'Intermediate', 'Advanced'] &&
             data.dialect is string;
    }

    function isValidPastLecture(data) {
      return data.keys().hasAll(['id', 'uid', 'title', 'summary', 'date']) &&
             data.id is string &&
             data.uid is string &&
             data.title is string &&
             data.summary is string &&
             data.date is number;
    }

    function isValidFeedback(data) {
      return data.keys().hasAll(['userId', 'lectureTitle', 'type', 'createdAt']) &&
             data.keys().size() >= 4 && data.keys().size() <= 5 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.lectureTitle is string && data.lectureTitle.size() <= 500 &&
             data.type in ['up', 'down'] &&
             (data.createdAt is timestamp || data.createdAt is string) &&
             (!('comment' in data) || (data.comment is string && data.comment.size() <= 2000));
    }

    function isValidPublicProfile(data) {
      return data.keys().hasAll(['uid', 'displayName', 'level']) &&
             data.keys().size() == 3 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 128 &&
             data.level in ['Beginner', 'Intermediate', 'Advanced'];
    }

    // ===============================================================
    // Match Blocks
    // ===============================================================

    match /admins/{adminEmail} {
      allow read: if isVerified();
      allow write: if isAdmin();
    }

    match /public_profiles/{profileId} {
      allow read: if isVerified();
      allow create, update: if isOwner(profileId) && isValidPublicProfile(incoming()) && isValidId(profileId);
    }

    match /feedbacks/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isVerified() && isValidFeedback(incoming()) && isValidId(feedbackId);
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && isValidUserProfile(incoming()) && incoming().uid == userId && isValidId(userId);
      
      allow update: if (isOwner(userId) && isValidUserProfile(incoming()) && incoming().uid == existing().uid) || isAdmin();

      match /lectures/{lectureId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidPastLecture(incoming()) && incoming().uid == userId && isValidId(lectureId);
        allow update: if isOwner(userId) && isValidPastLecture(incoming()) && incoming().uid == existing().uid;
        allow delete: if isOwner(userId) || isAdmin();
      }
    }
  }
}
